{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": [],
    "lib": ["ES2019", "DOM"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "outDir": "build",
    "removeComments": true
  },
  "include": ["src/**/*.ts"]
}
